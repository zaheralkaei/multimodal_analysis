# Generated data — downloaded/created by the pipeline, regenerable
data/raw/
data/processed/*.csv
data/processed/*.json
data/processed/*.wav
data/processed/*.mp4
data/processed/*.png
data/processed/*.npy
data/processed/*.npz
data/processed/**/*.jpg
# Per-video processed folders (generated when running on a different video)
data/processed_*/
data/processed_*/
data/processed_*/*.csv
data/processed_*/*.json
data/processed_*/*.wav
data/processed_*/*.mp4
data/processed_*/*.png
data/processed_*/*.npy
data/processed_*/*.npz
data/processed_*/**/*.jpg

# Reports — generated by analyze.py and dashboard.py
reports/*.csv
reports/*.png
reports/frames/  # dashboard thumbnails (copied from data/processed/frames)
# Per-video reports folders
reports_*/
reports_*/frames/

# Negations: allow markdown summaries and the dashboard HTML
!reports/*.md
!reports/*.html
!reports_*/dashboard.html

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
logs/*.log

# Environment variables / secrets
.env
.env.local
.env.*.local
