# Generated data — downloaded/created by the pipeline, regenerable
data/raw/
data/processed/*.csv
data/processed/*.json
data/processed/*.wav
data/processed/*.mp4
data/processed/*.png
data/processed/*.npy
data/processed/*.npz
data/processed/**/*.jpg
# But: preserve the 1fps baseline CSVs/JSONs (small files for comparison)
!data/processed_1fps_baseline/
!data/processed_1fps_baseline/*.csv
!data/processed_1fps_baseline/*.json
!data/processed_1fps_baseline/*.wav

# Reports — generated by analyze.py and dashboard.py
reports/*.csv
reports/*.png
# Negations: allow markdown summaries and the dashboard HTML
!reports/*.md
!reports/*.html

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
logs/*.log

# Environment variables / secrets
.env
.env.local
.env.*.local
