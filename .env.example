# Ollama cloud API key (https://ollama.com → Settings → API keys)
# Required for cloud models (qwen2.5vl:72b-cloud, etc.)
# Get one at: https://ollama.com/settings/keys
OLLAMA_API_KEY=your-key-here

# Which Ollama endpoint to use:
# - https://ollama.com/api        (cloud, requires OLLAMA_API_KEY)
# - http://localhost:11434/api   (local, no key needed)
OLLAMA_BASE_URL=https://ollama.com/api

# Vision model to use in phase 2. Available cloud models (vision-capable):
#   gemini-3-flash-preview   (Google, fast, good)
#   gemma3:27b               (Google, slow but detailed)
#   gemma4:31b               (Google, latest, fast)
#   gpt-oss:120b             (text-only — does NOT support images)
# Local fallback (no key needed, must fit in RAM):
#   gemma3:4b, qwen2.5vl:3b, qwen3-vl:8b
VISION_MODEL=gemini-3-flash-preview
